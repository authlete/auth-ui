# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# Authorization Server (the typescript-oauth-server we built)
AS_BASE_URL=http://localhost:3000

# auth-ui's first-party OAuth client at the AS
AS_CLIENT_ID=
# A single-line JWK JSON, including the private `d` component.
# Generated alongside the client registration in Authlete.
AS_CLIENT_PRIVATE_KEY=
AS_CLIENT_KEY_ALG=ES256

# Storage
SQLITE_DB_PATH=./data/auth-ui.sqlite

# Server
PORT=3001
NODE_ENV=development
